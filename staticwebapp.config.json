{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif}", "/css/*"]
  },
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    }
  ],
  "globalHeaders": {
    "cache-control": "public, max-age=3600"
  },
  "mimeTypes": {
    ".html": "text/html",
    ".json": "application/json"
  }
}
